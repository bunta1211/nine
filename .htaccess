# Social9 メイン.htaccess

# PHPエラー表示（開発環境用）
# php_flag display_errors on

# デフォルトの文字コード
AddDefaultCharset UTF-8

# 404 エラーページ（存在しないURL用・.htaccess と同じディレクトリの 404.php）
ErrorDocument 404 /404.php

# ディレクトリ一覧表示を無効化
Options -Indexes

# configディレクトリへのアクセスを禁止
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # configディレクトリ
    RewriteRule ^config/ - [F,L]
    
    # デプロイ確認用（本番ではアクセス禁止）
    RewriteRule ^api/server-check\.php$ - [F,L]
    
    # デバッグ・テスト用API（本番ではアクセス禁止）
    RewriteRule ^api/debug_login\.php$ - [F,L]
    RewriteRule ^api/debug_otp\.php$ - [F,L]
    RewriteRule ^api/test-helper\.php$ - [F,L]
    
    # tmpディレクトリ
    RewriteRule ^tmp/ - [F,L]
    
    # docsディレクトリ
    RewriteRule ^docs/ - [F,L]
    RewriteRule ^DOCS/ - [F,L]
    
    # databaseディレクトリ
    RewriteRule ^database/ - [F,L]
</IfModule>

# セキュリティヘッダー
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# PHPファイル以外の直接アクセスを制限（特定ファイル）
<FilesMatch "\.(sql|log|bak|conf|ini)$">
    Deny from all
</FilesMatch>

# ========== パフォーマンス最適化 ==========

# Gzip圧縮（転送サイズ削減 - 約70%）
<IfModule mod_deflate.c>
    # テキストベースのファイルを圧縮
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE image/svg+xml
    
    # 既に圧縮されたファイルは除外
    SetEnvIfNoCase Request_URI \.(?:gif|jpe?g|png|webp)$ no-gzip
</IfModule>

# ブラウザキャッシュ（リクエスト数削減）
<IfModule mod_expires.c>
    ExpiresActive On
    
    # 静的アセット（長期キャッシュ - ファイル名にバージョンあり）
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
    
    # 画像ファイル（長期キャッシュ）
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 month"
    
    # フォントファイル（長期キャッシュ）
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    
    # HTMLはキャッシュしない（常に最新）
    ExpiresByType text/html "access plus 0 seconds"
    
    # APIレスポンスはキャッシュしない
    ExpiresByType application/json "access plus 0 seconds"
</IfModule>

# ETags（キャッシュ検証）
<IfModule mod_headers.c>
    # 静的ファイルにETagを有効化
    FileETag MTime Size
    
    # Keep-Alive（コネクション再利用）
    Header set Connection keep-alive
</IfModule>








