# Guild アプリケーション .htaccess
# ※ php_flag / php_value は PHP-FPM では使えないため削除（本番 500 の原因になり得る）

# 文字コード設定
AddDefaultCharset UTF-8

# ディレクトリリスティングを無効化
Options -Indexes

# ファイルタイプ別のアクセス制限
<FilesMatch "\.(sql|log|md|txt)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# config、database、logsディレクトリへのアクセスを禁止
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^config/ - [F,L]
    RewriteRule ^database/ - [F,L]
    RewriteRule ^logs/ - [F,L]
    RewriteRule ^tmp/ - [F,L]
    RewriteRule ^includes/ - [F,L]
</IfModule>
